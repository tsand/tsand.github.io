{
    "name": "app",
    "version": "1.0.0",
    "dependencies": {
        "rehype": "^13.0.1",
        "rehype-highlight": "^7.0.0",
        "rehype-sanitize": "^6.0.0",
        "rehype-stringify": "^10.0.0",
        "remark": "^15.0.1",
        "remark-parse": "^11.0.0",
        "remark-rehype": "^11.0.0",
        "unified": "^11.0.3"
    },
    "devDependencies": {
        "esbuild": "0.19.4",
        "serve": "^14.2.1"
    },
    "scripts": {
        "clean": "rm -rf ./dist/*",
        "setup": "npm run clean && mkdir -p ./dist/assets && cp -r ./static ./dist/ && cp ./*.html ./dist/",
        "build": "npm run setup && esbuild `find ./src/ \\( -name '*.css' -o -name '*.js' \\)` --bundle $esbuild_flags --splitting --format=esm --external:*.woff2 --outdir=./dist/assets",
        "build-prod": "esbuild_flags='--minify' npm run build",
        "watch": "esbuild_flags='--watch' npm run build"
    }
}
